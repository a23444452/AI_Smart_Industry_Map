# backend
AISM_DB_PATH=./data/aism.db
AISM_CORS_ORIGINS=http://localhost:5173

# LLM（AI 分析）
# provider 切換：
#   mock          預設，零設定即可跑（回傳假資料，不呼叫外部 API）
#   anthropic     需設 AISM_LLM_API_KEY
#   openai_compat 需設 AISM_LLM_BASE_URL + AISM_LLM_API_KEY + AISM_LLM_MODEL
AISM_LLM_PROVIDER=mock
AISM_LLM_MODEL=claude-sonnet-5
AISM_LLM_API_KEY=
AISM_LLM_BASE_URL=

# frontend
VITE_API_BASE=http://localhost:8000
